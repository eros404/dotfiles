{{- range .hyprland.monitors }}
hl.monitor({
	output = "{{ .output }}",
	mode = "highresxhighrr",
	scale = 1,
	{{- if hasKey . "position" }}
	position = "{{ .position }}",
	{{- end }}
})

{{- if hasKey . "dpms" }}
hl.bind("SUPER + {{ .dpms }}", hl.dsp.dpms({ monitor = "{{ .output }}" }))
{{- end }}

{{- end }}
